MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.g6gac4j.mongodb.net/?appName=Cluster0
# Optional: override DNS for mongodb+srv (comma-separated). Dev uses 8.8.8.8/1.1.1.1 automatically if unset.
# MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1
MONGODB_DB_NAME=engagehub
JWT_SECRET=replace-with-a-long-random-secret
TOKEN_ENCRYPTION_KEY=replace-with-32-byte-key
PORT=4000
APP_BASE_URL=http://localhost:4000
CLIENT_BASE_URL=http://localhost:5173
# Frontend env lives in frontend/.env (see frontend/.env.example). Example:
# VITE_API_URL=http://localhost:4000

# Optional: GPT-powered caption generation on Create Post (falls back to built-in suggestions if unset)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Deployed API (Render): set on Render dashboard AND mirror OAuth redirect URIs to this host.
# APP_BASE_URL=https://engagehub.onrender.com
# CLIENT_BASE_URL=https://engage-hub-chi.vercel.app
# META_REDIRECT_URI=https://engagehub.onrender.com/api/social/meta/callback
# INSTAGRAM_REDIRECT_URI=https://engagehub.onrender.com/api/social/instagram/callback
# THREADS_REDIRECT_URI=https://engagehub.onrender.com/api/social/threads/callback
# (same host for LINKEDIN_*, GOOGLE_*, TWITTER_*, GITHUB_*, etc. — see paths below)
#
# Frontend-only dev against hosted API: set VITE_API_URL in frontend/.env

# Ngrok free tier shows an interstitial on the first browser visit — click "Visit Site" once (ngrok sets a cookie ~7 days).
# Programmatic requests use ngrok-skip-browser-warning (see frontend/src/utils/tunnelApiHeaders.js); browsers cannot send that on normal navigation.
# Browse Vite through ngrok: configure NGROK_HOST / VITE_* vars in frontend/.env (see frontend/.env.example).

# Facebook only — do not reuse these for Instagram or Threads.
META_APP_ID=your-facebook-meta-app-id
META_APP_SECRET=your-facebook-meta-app-secret
META_REDIRECT_URI=http://localhost:4000/api/social/meta/callback
META_CONFIG_ID=your-meta-config-id

# Facebook Login only requests public_profile + email unless you add scopes here (comma-separated).
# Page scopes require the right Meta app use case and often trigger “Invalid Scopes” until configured.
# Example: FACEBOOK_LOGIN_EXTRA_SCOPES=pages_show_list,pages_read_engagement,pages_manage_posts
FACEBOOK_LOGIN_EXTRA_SCOPES=

# Instagram API with Instagram Login — separate Meta app (App Dashboard → Instagram → Business login settings).
# Use the Instagram App ID and Instagram App secret from that app, not META_APP_ID / Facebook App ID.
INSTAGRAM_CLIENT_ID=your-instagram-app-id
INSTAGRAM_CLIENT_SECRET=your-instagram-app-secret
# Must match Meta → Instagram → Business login settings → OAuth redirect URIs exactly (no trailing slash unless Meta added one).
INSTAGRAM_REDIRECT_URI=http://localhost:4000/api/social/instagram/callback
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=choose-your-own-secret-verify-token

# Use Threads App ID + Secret from the SAME Meta app as your Threads use case:
# App settings → Basic → "Threads App ID" and "Threads App secret" (not Facebook App ID / META_APP_ID).
# After adding Facebook/Instagram use cases, re-copy these — old THREADS_* values often stop working.
# Redirect URI must match Meta → Use cases → Access the Threads API → Redirect Callback URLs exactly.
# Local dev: http://localhost:4000/api/social/threads/callback — connect + callback must hit the same API host.
THREADS_APP_ID=your-threads-app-id
THREADS_APP_SECRET=your-threads-app-secret
THREADS_REDIRECT_URI=http://localhost:4000/api/social/threads/callback

LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_REDIRECT_URI=http://localhost:4000/api/social/linkedin/callback
# Minimum: personal profile posting
LINKEDIN_SCOPES=openid profile email w_member_social
# Company pages (only if approved in LinkedIn Developer Portal — merged into OAuth automatically):
# LINKEDIN_ORG_SCOPES=rw_organization_admin w_organization_social r_organization_social r_organization_followers

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Local dev — use localhost URIs and register the SAME URLs in Google Cloud Console (OAuth client → Authorized redirect URIs):
GOOGLE_YOUTUBE_REDIRECT_URI=http://localhost:4000/api/social/youtube/callback
GOOGLE_REDIRECT_URI=http://localhost:4000/api/social/youtube/callback
GOOGLE_BUSINESS_REDIRECT_URI=http://localhost:4000/api/social/google-business/callback
# Production (Render) — you can add BOTH localhost and production URIs in Google Console:
# GOOGLE_YOUTUBE_REDIRECT_URI=https://engagehub.onrender.com/api/social/youtube/callback
# GOOGLE_REDIRECT_URI=https://engagehub.onrender.com/api/social/youtube/callback
# GOOGLE_BUSINESS_REDIRECT_URI=https://engagehub.onrender.com/api/social/google-business/callback
# APP_BASE_URL must match the host you use for OAuth callbacks (localhost:4000 locally, or your API host in production).
# Google Business Profile linking also requires (same GCP project as GOOGLE_CLIENT_ID):
# 1. Enable APIs: My Business Account Management API + My Business Business Information API
#    (API Library: https://console.cloud.google.com/apis/library)
# 2. OAuth consent screen → add scope https://www.googleapis.com/auth/business.manage
# 3. Authorized redirect URI must match GOOGLE_BUSINESS_REDIRECT_URI exactly (kebab-case path above)
# 4. Google may require GBP API access approval: https://developers.google.com/my-business/content/prereqs
# Dev-only: skip real Google API on publish (validates payload + returns fake postId). UI still needs a connected location.
# GOOGLE_BUSINESS_DRY_RUN=true
# Optional placeholders when connected to Google but you have zero real locations:
# GOOGLE_BUSINESS_DEBUG_ACCOUNT_ID=dry-run-account
# GOOGLE_BUSINESS_DEBUG_LOCATION_ID=dry-run-location
# Debug script without EngageHUB: npm run debug:google-business-post
# Live API test: npm run debug:google-business-post -- --live --token=... --account=... --location=...
# User sign-in (login/signup). Add this exact URI in Google Cloud Console → OAuth client → Authorized redirect URIs.
GOOGLE_AUTH_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret
TWITTER_REDIRECT_URI=http://localhost:4000/api/social/x/callback

GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret
GITHUB_REDIRECT_URI=http://localhost:4000/api/social/github/callback
# Optional: override default scopes (read:user user:email repo)
# GITHUB_SCOPES=read:user,user:email,repo


REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_REDIRECT_URI=http://localhost:4000/api/social/reddit/callback

PINTEREST_APP_ID=your-pinterest-app-id
PINTEREST_APP_SECRET=your-pinterest-app-secret
PINTEREST_REDIRECT_URI=http://localhost:4000/api/social/pinterest/callback

DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_REDIRECT_URI=http://localhost:4000/api/social/discord/callback
DISCORD_BOT_TOKEN=your-discord-bot-token

TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_USERNAME=your-telegram-bot-username
